// prettier-ignore
{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "default_agent": "build",

  "permission": {
    "skill": {
      "*": "allow",
      "pr-review": "allow",
      "internal-*": "deny",
      "experimental-*": "ask"
    },
    "read": {
      "*.env*": "ask",
      "*": "allow"
    },
    "bash": {
      "cat *.env*": "ask",
      "*": "allow"
    }
  },

  "agent": {
    "build": {
      "mode": "primary",
      "model": "opencode/deepseek-v4-flash-free",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      },
      "reasoningEffort": "high",
      "textVerbosity": "low"
    },
    "plan": {
      "mode": "primary",
      "model": "google/gemini-2.5-flash",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "project-architect": {
      "mode": "subagent",
      "model": "opencode/big-pickle",
      "description": "system architect for the NextJS Auth Starter Kit project.",
      "prompt": "{file:.agents/agents/architect.md}",
      "temperature": 0.1,
      "permission": {
        "edit": "ask",
        "bash": "allow"
      }
    },
    "code-reviewer": {
      "mode": "subagent",
      "model": "google/gemini-2.5-flash",
      "description": "perform code review and quality assurance for the NextJS Auth Starter Kit.",
      "prompt": "{file:.agents/agents/reviewer.md}",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": "allow"
      }
    },
    "code-builder": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "implementation executor for the NextJS Auth Starter Kit project.",
      "prompt": "{file:.agents/agents/builder.md}",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "docs-writer": {
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "description": "generate and maintain documentation for the NextJS Auth Starter Kit.",
      "prompt": "{file:.agents/agents/docs-writer.md}",
      "permission": {
        "edit": "allow",
        "bash": "ask"
      }
    }
  }
}
