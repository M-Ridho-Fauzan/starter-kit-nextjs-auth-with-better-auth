# ═══════════════════════════════════════════
# NextJS Auth Starter Kit — Environment Variables
# ═══════════════════════════════════════════

# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Database ───

# Database connection URL
DATABASE_URL=

# ─── Better Auth ───

# Secret key for token signing (min 32 characters, generate with `openssl rand -base64 32`)
BETTER_AUTH_SECRET=

# Your application's public URL
BETTER_AUTH_URL=http://localhost:3000

# ─── OAuth Providers ───

# GitHub OAuth App client ID
GITHUB_CLIENT_ID=

# GitHub OAuth App client secret
GITHUB_CLIENT_SECRET=

# Google OAuth client ID (required when Google OAuth is enabled)
# GOOGLE_CLIENT_ID=

# Google OAuth client secret (required when Google OAuth is enabled)
# GOOGLE_CLIENT_SECRET=
